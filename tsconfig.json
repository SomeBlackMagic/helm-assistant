{
  "compilerOptions": {
    /* Basic Options */
    "target": "ES2022",
    "module": "commonjs",
    "sourceMap": true,
    "outDir": "./dist/",
    "rootDir": "./src/",
    "removeComments": true,
    "importHelpers": true,

    /* Strict Type-Checking Options */
    "strict": true,
    "skipLibCheck": true,

    /* Module Resolution Options */
    "esModuleInterop": true,
    "moduleResolution": "node",
    "baseUrl": "./src/",
    "typeRoots": [
      "node_modules/@types",
      "@types"
    ],
    "types": [
      "node"
    ]
  },
  "exclude": [
    "node_modules",
    "test"
  ],
  "typedocOptions": {
    "name": "Node Monitoring TypeScript Path Mapper",
    "out": "dist/docs",
    "readme": "docs/README.md",
    "hideGenerator": true,
    "excludePrivate": true,
    "excludeExternal": true,
    "logger": "none",
    "exclude": "**/*.test.ts"
  }
}
